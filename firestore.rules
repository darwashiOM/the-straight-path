rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Public read, admin write
    match /articles/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /videos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /links/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /faqs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /resources/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /channels/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /series/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /topics/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /siteSettings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pages/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /media/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Audit log — append-only by admins, readable by admins.
    match /auditLog/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Write-only public, admin read
    match /contact-submissions/{id} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 5000
        && request.resource.data.name.size() <= 120
        && request.resource.data.email.size() <= 200;
      allow read, update, delete: if isAdmin();
    }

    // Admins collection — self-readable, admin-manageable
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
